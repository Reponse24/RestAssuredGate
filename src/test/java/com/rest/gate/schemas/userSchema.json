{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "required": ["id", "firstName", "lastName", "email"],
  "properties": {
    "id":        { "type": "integer" },
    "firstName": { "type": "string" },
    "lastName":  { "type": "string" },
    "email":     { "type": "string", "format": "email" },
    "age":       { "type": "integer", "minimum": 0 }
  }
}